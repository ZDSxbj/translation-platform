#ifndef C2R_CPP_STUB_VECTOR
#define C2R_CPP_STUB_VECTOR

#include <stddef.h>

namespace std {

template<typename T>
class vector {
public:
    typedef T value_type;
    typedef size_t size_type;

    vector();
    ~vector();
    size_type size() const;
    bool empty() const;
    T& operator[](size_type idx);
    const T& operator[](size_type idx) const;
    T* data();

private:
    T* _data;
    size_type _size;
    size_type _capacity;
};

}  // namespace std

#endif
