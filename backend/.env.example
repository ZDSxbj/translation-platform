API_KEY=YOUR_API_KEY
API_BASE_URL=https://api.apiyi.com/v1
API_MODEL=deepseek-v3.2
API_MAX_TOKENS=8192
API_TEMPERATURE=0.0
API_TIMEOUT=600.0

FLASK_ENV=development
UPLOAD_FOLDER=./uploads
OUTPUT_FOLDER=./outputs
MAX_CONTENT_LENGTH=524288000
CORS_ORIGINS=*

# His2Trans Framework Path (parent of framework/)
HIS2TRANS_FRAMEWORK=/absolute/path/to/His2Trans-Opt-/framework
HIS2TRANS_DATA=/absolute/path/to/His2Trans-Opt-/data

# Jina Reranker GPU Settings (lower threshold avoids GPU wait-loop)
JINA_MIN_MEMORY_GB=4.0
JINA_RERANKER_BATCH_SIZE=8

# LLM Retry Settings
VLLM_MAX_RETRIES=3
VLLM_REQUEST_TIMEOUT=600
